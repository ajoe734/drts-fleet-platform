{
  "name": "@drts/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm --filter @drts/contracts build && tsc -p tsconfig.json",
    "dev": "node --watch -r ts-node/register src/main.ts",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm --filter @drts/contracts build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@drts/contracts": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/throttler": "^6.5.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6"
  }
}
