{
  "name": "drts-fleet-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "build": "turbo run build",
    "check": "./scripts/check.sh",
    "db:init": "./scripts/db-init-local.sh",
    "db:migrate": "./scripts/db-apply.sh",
    "db:seed": "./scripts/db-seed.sh all",
    "db:seed:demo": "./scripts/db-seed.sh demo",
    "db:seed:reference": "./scripts/db-seed.sh reference",
    "db:verify": "./scripts/db-verify.sh",
    "dev": "turbo run dev --parallel --continue",
    "dev:api": "pnpm --filter @drts/api dev",
    "dev:down": "./scripts/dev-down.sh",
    "dev:driver": "pnpm --filter @drts/driver-app dev",
    "dev:driver:android": "pnpm --filter @drts/driver-app android",
    "dev:driver:client": "pnpm --filter @drts/driver-app dev:client",
    "dev:driver:ios": "pnpm --filter @drts/driver-app ios",
    "dev:driver:web": "pnpm --filter @drts/driver-app web",
    "dev:ops": "pnpm --filter @drts/ops-console-web dev",
    "dev:platform-admin": "pnpm --filter @drts/platform-admin-web dev",
    "dev:tenant": "pnpm --filter @drts/tenant-console-web dev",
    "dev:up": "./scripts/dev-up.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:root": "eslint eslint.config.mjs playwright.config.ts vitest.config.ts tests --max-warnings=0",
    "orchestrator:dashboard": "bash scripts/run-dashboard.sh",
    "orchestrator:dashboard:tunnel": "bash scripts/run-dashboard-tunnel.sh",
    "orchestrator:dashboard:public": "HOST=0.0.0.0 bash scripts/run-dashboard.sh",
    "orchestrator:setup": "bash scripts/setup-llm-cli.sh",
    "orchestrator:supervisor": "bash scripts/run-supervisor.sh --verbose",
    "orchestrator:test": "python3 -m unittest discover -s .orchestrator -p 'test_*.py'",
    "phase1:verify:all": "./scripts/phase1-rollout-verify.sh all",
    "phase1:verify:backfill": "./scripts/phase1-rollout-verify.sh backfill",
    "phase1:verify:pilot": "./scripts/phase1-rollout-verify.sh pilot",
    "phase1:verify:production": "./scripts/phase1-rollout-verify.sh production",
    "phase1:verify:uat": "./scripts/phase1-rollout-verify.sh uat",
    "prepare": "husky",
    "test": "pnpm test:unit && turbo run test",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "typecheck": "pnpm typecheck:root && turbo run typecheck",
    "typecheck:root": "tsc -p tsconfig.json --noEmit"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.1.4"
  }
}
