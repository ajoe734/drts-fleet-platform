{
  "name": "@drts/ui-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Cross-stack design tokens for DRTS UI.",
  "keywords": [
    "design-tokens",
    "ui-tokens",
    "drts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "author": "Codex2",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "tsup": "^8.0.1",
    "typescript": "^5.4.2"
  }
}
