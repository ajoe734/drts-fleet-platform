{
  "paths": {
    "status_file": "ai-status.json",
    "activity_log": "ai-activity-log.jsonl",
    "current_work": "current-work.md",
    "dashboard": "docs-site/index.html",
    "state_file": ".orchestrator/state.json",
    "event_queue": ".orchestrator/event-queue.jsonl",
    "approval_queue": ".orchestrator/approval-queue.json",
    "sidecar_catalog": ".orchestrator/sidecar_catalog.json",
    "github_bus_state": ".orchestrator/github-bus-state.json",
    "github_webhook_events": ".orchestrator/github-webhook-events.jsonl",
    "github_relay_state": ".orchestrator/github-relay-state.json",
    "provider_capabilities": ".orchestrator/provider_capabilities.json",
    "claude_mcp_config": ".orchestrator/claude-approval-broker.mcp.json"
  },
  "watcher": {
    "poll_interval_seconds": 2.0,
    "replay_on_start": false,
    "max_seen_events": 2000
  },
  "supervisor": {
    "poll_interval_seconds": 2.0,
    "heartbeat_warn_after_seconds": 10.0,
    "stall_after_seconds": 300,
    "max_worker_history": 200,
    "auto_refresh_provider_capabilities": false
  },
  "worker_retry": {
    "enabled": true,
    "max_attempts": 5,
    "backoff_schedule_seconds": [5, 15, 30, 60, 120],
    "jitter_seconds": 3,
    "transient_error_patterns": [
      "429",
      "resource_exhausted",
      "rate limit",
      "rate limited",
      "timed out",
      "etimedout",
      "econnreset",
      "temporarily unavailable",
      "try again later",
      "server overloaded",
      "deadline exceeded",
      "terminalquotaerror",
      "retryablequotaerror",
      "quota_exhausted",
      "quota exhausted",
      "exhausted your capacity",
      "no capacity available for model"
    ],
    "fallback_mode": "file_inbox"
  },
  "worker_reassignment": {
    "enabled": true,
    "after_attempts": 2,
    "reassign_on_terminal_failure": true,
    "eligible_statuses": [
      "backlog",
      "todo",
      "in_progress",
      "review",
      "review_approved"
    ],
    "owner_fallbacks": {
      "Claude": ["Codex", "Codex2", "Qwen", "Copilot", "Gemini"],
      "Gemini": ["Codex", "Codex2", "Qwen", "Claude", "Copilot"],
      "Codex": ["Codex2", "Qwen", "Claude", "Copilot", "Gemini"],
      "Codex2": ["Codex", "Qwen", "Claude", "Copilot", "Gemini"],
      "Copilot": ["Codex", "Codex2", "Qwen", "Claude", "Gemini"],
      "Qwen": ["Codex", "Codex2", "Claude", "Copilot", "Gemini"]
    },
    "reviewer_fallbacks": {
      "Claude": ["Codex", "Codex2", "Qwen", "Copilot", "Gemini"],
      "Gemini": ["Codex", "Codex2", "Qwen", "Claude", "Copilot"],
      "Codex": ["Codex2", "Qwen", "Claude", "Copilot", "Gemini"],
      "Codex2": ["Codex", "Qwen", "Claude", "Copilot", "Gemini"],
      "Copilot": ["Codex", "Codex2", "Qwen", "Claude", "Gemini"],
      "Qwen": ["Codex", "Codex2", "Claude", "Copilot", "Gemini"]
    }
  },
  "underutilization_dispatch": {
    "enabled": true,
    "threshold_ratio": 0.5,
    "continuous_window_seconds": 900,
    "cooldown_seconds": 900,
    "max_new_sidecars_per_wave": 2,
    "max_new_main_tasks_per_wave": 2,
    "max_active_sidecars_per_agent": 1,
    "productive_worker_statuses": [
      "running",
      "waiting_approval",
      "suspended_approval",
      "retry_backoff"
    ]
  },
  "approvals": {
    "stale_pending_seconds": 1800
  },
  "github_bus": {
    "enabled": false,
    "command_timeout_seconds": 8,
    "poll_interval_seconds": 30,
    "repo": null,
    "default_branch": "master",
    "offline_backoff_seconds": 300,
    "auto_request_reviewers": false,
    "close_resolved_issues": false,
    "labels": {
      "review": ["pantheon-bus", "pantheon-review"],
      "ops": ["pantheon-bus", "pantheon-ops", "approval-needed"],
      "resolved": ["resolved"]
    },
    "commands": [
      "/approve",
      "/deny",
      "/retry",
      "/resume",
      "/recheck",
      "/status"
    ],
    "reviewers": {
      "Claude": ["your-github-handle"],
      "Gemini": ["your-github-handle"],
      "Codex": ["your-github-handle"],
      "Qwen": ["your-github-handle"],
      "Copilot": ["your-github-handle"]
    },
    "templates": {
      "ops_issue": ".orchestrator/templates/github_ops_issue.md",
      "review_pr": ".orchestrator/templates/github_review_pr.md"
    },
    "phase3": {
      "github_app": {
        "enabled": false,
        "app_id_env": "PANTHEON_GITHUB_APP_ID",
        "private_key_env": "PANTHEON_GITHUB_APP_PRIVATE_KEY",
        "installation_id_env": "PANTHEON_GITHUB_INSTALLATION_ID"
      },
      "webhook": {
        "enabled": false,
        "host": "127.0.0.1",
        "port": 8776,
        "secret_env": "PANTHEON_GITHUB_WEBHOOK_SECRET"
      },
      "cloud_relay": {
        "enabled": false,
        "url_env": "PANTHEON_GITHUB_RELAY_URL",
        "token_env": "PANTHEON_GITHUB_RELAY_TOKEN"
      }
    }
  },
  "schema": {
    "tasks_path": "tasks",
    "handoffs_path": "handoffs",
    "task_id_field": "id",
    "status_field": "status",
    "assignee_field": "owner",
    "reviewer_field": "reviewer",
    "artifacts_field": "artifacts",
    "next_field": "next",
    "last_update_field": "last_update"
  },
  "events": {
    "enqueue_runtime_events": false,
    "review_statuses": ["review"],
    "status_targets": {
      "needs_reply": "owner",
      "needs_input": "owner",
      "handoff": "owner"
    },
    "waiting_status_patterns": ["^waiting_on_(?P<agent>[A-Za-z0-9_-]+)$"],
    "watch_assignee_changes": false,
    "watch_reviewer_changes": false,
    "watch_handoffs": false,
    "pending_handoff_statuses": ["pending"]
  },
  "agents": {
    "claude": {
      "display_name": "Claude",
      "provider": "claude",
      "adapter": "claude_cli",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/claude.md"
    },
    "gemini": {
      "display_name": "Gemini",
      "provider": "gemini",
      "adapter": "gemini",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/gemini.md"
    },
    "codex": {
      "display_name": "Codex",
      "provider": "codex",
      "adapter": "codex",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/codex.md"
    },
    "codex2": {
      "display_name": "Codex2",
      "provider": "codex2",
      "adapter": "codex",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/codex2.md"
    },
    "copilot": {
      "display_name": "Copilot",
      "provider": "copilot",
      "adapter": "copilot_local",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/copilot.md"
    },
    "qwen": {
      "display_name": "Qwen",
      "provider": "qwen",
      "adapter": "qwen",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/qwen.md"
    },
    "grok": {
      "display_name": "Copilot (legacy alias)",
      "provider": "copilot",
      "adapter": "copilot_local",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/grok.md"
    }
  },
  "providers": {
    "claude": {
      "delivery_mode": "claude_cli",
      "file_inbox": {
        "path": ".llm-inbox/claude.md",
        "open_in_vscode": false
      },
      "runtime": {
        "cli": "claude",
        "output_format": "stream-json",
        "include_hook_events": true,
        "permission_mode": "acceptEdits",
        "resume_permission_mode_after_approval": "acceptEdits",
        "resume_use_allowed_tools_from_approval": true,
        "enable_auto_mode_if_supported": true,
        "auto_permission_mode": "auto",
        "mcp_config": ".orchestrator/claude-approval-broker.mcp.json",
        "permission_prompt_tool": "mcp__orchestrator_approval_broker__approval_prompt"
      },
      "broker": {
        "approval_wait_seconds": 3600,
        "http_host": "127.0.0.1",
        "http_port": 8765,
        "persist_allow_by_default": false
      },
      "approval": {
        "workspace_permission_mode": "acceptEdits",
        "allow_dangerous_skip": false,
        "copilot_allow_dangerous_skip": false,
        "rule_default_mode": "acceptEdits",
        "disable_bypass_permissions": true
      }
    },
    "gemini": {
      "delivery_mode": "gemini",
      "file_inbox": {
        "path": ".llm-inbox/gemini.md",
        "open_in_vscode": false
      },
      "gemini": {
        "cli": "gemini",
        "include_directories": true
      },
      "approval": {
        "default_approval_mode": "auto_edit",
        "workspace_agent_yolo_mode": false,
        "enable_permanent_tool_approval": true,
        "auto_add_to_policy_by_default": true,
        "disable_yolo_mode": false,
        "disable_always_allow": false
      }
    },
    "codex": {
      "delivery_mode": "codex",
      "file_inbox": {
        "path": ".llm-inbox/codex.md",
        "open_in_vscode": false
      },
      "codex": {
        "cli": "codex",
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      },
      "approval": {
        "orchestrator_only": true,
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      }
    },
    "codex2": {
      "delivery_mode": "codex",
      "file_inbox": {
        "path": ".llm-inbox/codex2.md",
        "open_in_vscode": false
      },
      "codex": {
        "cli": "codex",
        "config_home": "~/.codex2",
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      },
      "approval": {
        "orchestrator_only": true,
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      }
    },
    "copilot": {
      "delivery_mode": "copilot_local",
      "file_inbox": {
        "path": ".llm-inbox/copilot.md",
        "open_in_vscode": false,
        "agent_paths": {
          "grok": ".llm-inbox/grok.md",
          "copilot": ".llm-inbox/copilot.md"
        }
      },
      "local": {
        "cli": "copilot",
        "autopilot": true,
        "max_autopilot_continues": 12,
        "allow_all_tools": true,
        "add_workspace_dir": true,
        "no_ask_user": true,
        "allow_tools": [],
        "deny_tools": [],
        "extra_args": []
      },
      "cloud": {
        "cli": "gh",
        "enabled": true,
        "min_version": "2.80.0",
        "follow": false,
        "base_branch": "main",
        "repo": null,
        "extra_args": []
      },
      "model_preference": {
        "default": null,
        "grok": null,
        "supported": []
      }
    },
    "qwen": {
      "delivery_mode": "qwen",
      "file_inbox": {
        "path": ".llm-inbox/qwen.md",
        "open_in_vscode": false
      },
      "qwen": {
        "cli": "qwen",
        "approval_mode": "yolo",
        "include_directories": true,
        "output_format": "stream-json",
        "include_partial_messages": false,
        "channel": "CI",
        "auth_type": null,
        "model": null,
        "model_env": "OPENAI_MODEL",
        "openai_api_key_env": "OPENAI_API_KEY",
        "openai_base_url_env": "OPENAI_BASE_URL",
        "extra_args": []
      }
    }
  },
  "ready_dispatcher": {
    "enabled": true,
    "review_statuses": ["review"],
    "finalize_statuses": ["review_approved"],
    "owned_statuses": ["in_progress", "todo", "backlog"],
    "dependency_done_statuses": ["done"],
    "worker_terminal_statuses": ["done", "review_approved"],
    "active_worker_statuses": [
      "running",
      "waiting_approval",
      "suspended_approval",
      "retry_backoff",
      "manual_pending",
      "stalled"
    ],
    "helper_claim": {
      "enabled": true,
      "task_statuses": [
        "backlog",
        "todo",
        "in_progress",
        "review",
        "review_approved"
      ],
      "availability_first": true,
      "allow_any_idle_lane": true,
      "prefer_assigned_when_idle": true,
      "require_assigned_agent_busy": true,
      "require_owner_higher_priority_load": false
    },
    "max_tasks_per_agent": 1,
    "max_dispatches_per_tick": 4
  }
}
